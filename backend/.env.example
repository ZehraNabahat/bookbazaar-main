NODE_ENV=development
PORT=5000
# MongoDB Atlas (recommended for production / Railway):
# MONGO_URI=mongodb+srv://<db_user>:<password>@<cluster>.mongodb.net/ecommerce-ai?retryWrites=true&w=majority
# Local MongoDB Compass:
MONGO_URI=mongodb://localhost:27017/ecommerce-ai
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:3000
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=pkr
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
REVIEW_AUTO_APPROVE=false
